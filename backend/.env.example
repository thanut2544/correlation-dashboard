PORT=4000
WS_PATH=/ws
SYMBOLS=EURUSD,GBPUSD,XAUUSD,JPY,USDJPY,AUDUSD,USDCHF,USDCAD,NZDUSD
CORR_WINDOW=120
CORR_INTERVAL_MS=60000
THRESHOLD_LOW=-0.5
THRESHOLD_HIGH=0.8

# Redis — required for trade persistence and price history in production
REDIS_URL=redis://localhost:6379
REDIS_NAMESPACE=prices

# CORS — comma-separated list of allowed frontend origins
ALLOWED_ORIGINS=http://localhost:3000

# Webhook authentication — set a strong secret and sign requests with HMAC-SHA256
# Header: x-webhook-secret: <hmac_hex>
# Leave blank to disable authentication (dev only)
WEBHOOK_SECRET=

# Strategy parameters
CORR_SHORT_WINDOW=60
CORR_MID_WINDOW=240
CORR_STABILITY_MAX_DIFF=0.15
CORR_STABILITY_VOL=0.2
Z_ENTRY=2
Z_ENTRY_STRICT=2.5
Z_TP=0.5
Z_STOP_LOSS=3.5
EMA_FAST=50
EMA_SLOW=200
RSI_PERIOD=14
ATR_PERIOD=14
ATR_MIN=0
ATR_MAX=999999
ALLOW_SESSIONS=london,ny
